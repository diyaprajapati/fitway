# Copy to .env and fill in values.

DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/fitway"

# Required for Auth.js (generate: openssl rand -base64 32).
# Keep stable; changing it invalidates existing session cookies (sign in again or clear site cookies).
